  "logotype": {
    "format": "css_pure",
    "implementation": "HTML/CSS only — no image file required",
    "font_family": "Bebas Neue",
    "font_source": "https://fonts.googleapis.com/css2?family=Bebas+Neue",
    "markup": "<span class=\"logotype\"><span class=\"lt-un\">UNREAL</span><span class=\"lt-chevron\">></span><span class=\"lt-ille\">ILLE</span><span class=\"lt-studio\">STUDIO</span></span>",
    "css_tokens": {
      "lt-un": "color: var(--chalk, #F2F0EC)",
      "lt-chevron": "color: var(--cyan, #00FFD1); transform: scaleY(1.45) scaleX(0.72); transform-origin: center; display: inline-block; letter-spacing: 0; margin: 0 -0.01em",
      "lt-ille": "color: var(--chalk, #F2F0EC)",
      "lt-studio": "color: rgba(242,240,236,0.32); margin-left: 0.18em; font-size: 0.72em; letter-spacing: 0.14em"
    },
    "sizes": {
      "nav": "font-size: 20px (lt-studio: 14px)",
      "footer": "font-size: 28px (lt-studio: 20px)",
      "inline": "font-size: 16px (lt-studio: 11px)"
    },
    "letter_spacing": "0.04em on .logotype wrapper",
    "chevron_animation": {
      "required": true,
      "rule": "ALWAYS blinking — no exceptions in any context including favicon",
      "css_keyframes": "@keyframes chevron-blink { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0; } }",
      "css_animation": "animation: chevron-blink 1s step-start infinite",
      "class": "lt-chevron",
      "note": "step-start for hard cut blink, not fade"
    },
    "studio_note": "STUDIO must be visually much darker than UNREAL>ILLE — not same weight. Use 0.32 opacity max. Never use same color/weight as main logotype text."
  },
